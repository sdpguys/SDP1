


<p style="color: green"><%= notice %></p>

<% content_for :title, "Courses" %>


<h1>Courses</h1>

<div id="courses">
  <% @courses.each do |course| %>
    <%= render course %>
    <p>
      <%= link_to "Show course", course, class:"btn btn-secondary"%>
    </p>
  <% end %>
</div>

<%= link_to "New course", new_course_path, class:"btn btn-secondary" %>







